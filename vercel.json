{
  "version": 2,
  "buildCommand": "",
  "public": true,
  "routes": [
    {
      "src": "/results/(.*\\.csv)$",
      "dest": "/results/$1"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/visualization/assets/$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|svg|ico))$",
      "dest": "/visualization/$1"
    },
    {
      "src": "/.*",
      "dest": "/visualization/Index.html"
    }
  ]
}
